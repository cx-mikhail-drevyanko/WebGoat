        "operationId": "login",
        "tags": ["Authentication"],
        "security": [],
        "parameters": [
          {
            "in": "formData",
            "name": "username",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "password",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful - session cookie set without Secure flag"
          },
          "302": {
            "description": "Redirect"
          }
        }
