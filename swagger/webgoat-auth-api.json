        "summary": "Get stored XSS entries",
        "operationId": "storedXssGet",
        "tags": ["XSS"],
        "responses": {
          "200": {
            "description": "Stored XSS entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer"
                      },
                      "text": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Submit stored XSS entry",
        "operationId": "storedXssPost",
        "tags": ["XSS"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
