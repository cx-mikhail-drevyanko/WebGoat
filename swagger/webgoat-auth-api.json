            "description": "Entry stored"
          }
        }
      }
    },
    "/LogSpoofing/log-spoofing": {
      "post": {
        "summary": "Log spoofing attack",
        "operationId": "logSpoofing",
        "tags": ["Log Spoofing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
