                    "type": "integer"
                  },
                  "text": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Submit stored XSS",
        "operationId": "storedXssPost",
        "tags": ["XSS"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stored"
          }
        }
      }
    },
