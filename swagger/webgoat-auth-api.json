{
  "swagger": "2.0",
  "info": {
    "title": "WebGoat Authentication & Session API",
    "description": "Authentication, JWT, CSRF, Password Reset, and XSS lesson endpoints",
    "version": "1.0.0",
    "contact": {
      "name": "WebGoat Security"
    }
  },
  "host": "localhost:8080",
  "basePath": "/WebGoat",
  "schemes": [
    "http"
  ],
  "consumes": [
    "application/json",
    "application/x-www-form-urlencoded"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "BasicAuth": {
      "type": "basic"
    },
    "ApiKeyAuth": {
      "type": "apiKey",
      "in": "query",
      "name": "api_key"
    },
    "BearerAuth": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization"
    }
  },
  "paths": {
    "/login": {
      "post": {
        "summary": "User login - credentials sent over HTTP",
        "operationId": "login",
        "tags": ["Authentication"],
        "parameters": [
          {
            "in": "formData",
            "name": "username",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "password",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "302": {
            "description": "Redirect after login"
          }
        }
      }
    },
    "/register.mvc": {
      "post": {
        "summary": "Register new user",
        "operationId": "registerUser",
        "tags": ["Authentication"],
        "parameters": [
          {
            "in": "formData",
            "name": "username",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "email",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "password",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "matchingPassword",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Registration successful"
          }
        }
      }
    },
    "/JWT/decode": {
      "post": {
        "summary": "Decode JWT token",
        "operationId": "jwtDecode",
        "tags": ["JWT"],
        "parameters": [
          {
            "in": "formData",
            "name": "token",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Decoded token contents"
          }
        }
      }
    },
    "/JWT/votings": {
      "get": {
        "summary": "Get all voting items",
        "operationId": "jwtVotingsGet",
        "tags": ["JWT"],
        "parameters": [
          {
            "name": "Authorization",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Voting list",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "votes": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/JWT/votings/{title}": {
      "post": {
        "summary": "Vote for an item",
        "operationId": "jwtVote",
        "tags": ["JWT"],
        "parameters": [
          {
            "name": "title",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "formData",
            "name": "token",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Vote registered"
          }
        }
      }
    },
    "/JWT/votings/login": {
      "put": {
        "summary": "JWT votings login",
        "operationId": "jwtVotingsLogin",
        "tags": ["JWT"],
        "parameters": [
          {
            "in": "body",
            "name": "credentials",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "user": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JWT token returned"
          }
        }
      }
    },
    "/JWT/secret/gettoken": {
      "get": {
        "summary": "Get JWT secret token",
        "operationId": "jwtGetToken",
        "tags": ["JWT"],
        "parameters": [
          {
            "name": "user",
            "in": "query",
            "type": "string",
            "required": false
          },
          {
            "name": "secretToken",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Token"
          }
        }
      }
    },
    "/JWT/secret": {
      "post": {
        "summary": "Submit JWT secret for verification",
        "operationId": "jwtSecret",
        "tags": ["JWT"],
        "parameters": [
          {
            "in": "formData",
            "name": "token",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "secretKey",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Validation result"
          }
        }
      }
    },
    "/JWT/refresh/checkout": {
      "post": {
        "summary": "JWT refresh - checkout",
        "operationId": "jwtRefreshCheckout",
        "tags": ["JWT"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "token": {
                  "type": "string"
                },
                "cart": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Checkout result"
          }
        }
      }
    },
    "/JWT/refresh/newToken": {
      "get": {
        "summary": "Get new JWT via credentials in query",
        "operationId": "jwtNewToken",
        "tags": ["JWT"],
        "parameters": [
          {
            "name": "userName",
            "in": "query",
            "type": "string",
            "required": false
          },
          {
            "name": "password",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "New token"
          }
        }
      }
    },
    "/HijackSession/login": {
      "post": {
        "summary": "Session hijack login",
        "operationId": "hijackSessionLogin",
        "tags": ["Session Hijacking"],
        "parameters": [
          {
            "in": "formData",
            "name": "username",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "password",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Session set"
          }
        }
      }
    },
    "/SpoofCookie/login": {
      "post": {
        "summary": "Cookie spoofing login",
        "operationId": "spoofCookieLogin",
        "tags": ["Cookie Spoofing"],
        "parameters": [
          {
            "in": "formData",
            "name": "username",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "password",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Login result with cookie"
          }
        }
      }
    },
    "/PasswordReset/ForgotPassword/create-password-reset-link": {
      "post": {
        "summary": "Create password reset link",
        "operationId": "createPasswordResetLink",
        "tags": ["Password Reset"],
        "parameters": [
          {
            "in": "formData",
            "name": "email",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Reset link sent"
          }
        }
      }
    },
    "/PasswordReset/reset/reset-password/{link}": {
      "get": {
        "summary": "Get reset form",
        "operationId": "getPasswordResetForm",
        "tags": ["Password Reset"],
        "parameters": [
          {
            "name": "link",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Reset form"
          }
        }
      },
      "post": {
        "summary": "Submit password reset",
        "operationId": "submitPasswordReset",
        "tags": ["Password Reset"],
        "parameters": [
          {
            "name": "link",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "newPassword": {
                  "type": "string"
                },
                "confirmPassword": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Password reset"
          }
        }
      }
    },
    "/PasswordReset/SecurityQuestions": {
      "get": {
        "summary": "Get security questions",
        "operationId": "getSecurityQuestions",
        "tags": ["Password Reset"],
        "responses": {
          "200": {
            "description": "Security questions",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "post": {
        "summary": "Verify security question",
        "operationId": "submitSecurityQuestion",
        "tags": ["Password Reset"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string"
                },
                "securityQuestion": {
                  "type": "string"
                },
                "answer": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Verification result"
          }
        }
      }
    },
    "/PasswordReset/reset/login": {
      "post": {
        "summary": "Login after password reset",
        "operationId": "loginAfterReset",
        "tags": ["Password Reset"],
        "parameters": [
          {
            "in": "formData",
            "name": "username",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "password",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Login result"
          }
        }
      }
    },
    "/csrf/feedback": {
      "post": {
        "summary": "Submit CSRF feedback",
        "operationId": "csrfFeedback",
        "tags": ["CSRF"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "comment": {
                  "type": "string"
                },
                "csrf": {
                  "type": "string"
                },
                "username": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feedback submitted"
          }
        }
      }
    },
    "/csrf/review": {
      "get": {
        "summary": "Get CSRF review page",
        "operationId": "csrfReviewGet",
        "tags": ["CSRF"],
        "responses": {
          "200": {
            "description": "Review page"
          }
        }
      },
      "post": {
        "summary": "Submit review",
        "operationId": "csrfReviewPost",
        "tags": ["CSRF"],
        "parameters": [
          {
            "in": "formData",
            "name": "reviewText",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "stars",
            "type": "integer",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Review submitted"
          }
        }
      }
    },
    "/InsecureLogin/login": {
      "post": {
        "summary": "Insecure login - plaintext credentials",
        "operationId": "insecureLogin",
        "tags": ["Insecure Login"],
        "parameters": [
          {
            "in": "body",
            "name": "credentials",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login result"
          }
        }
      }
    },
    "/InsecureLogin/task": {
      "get": {
        "summary": "Insecure login with credentials in query",
        "operationId": "insecureLoginTask",
        "tags": ["Insecure Login"],
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "type": "string",
            "required": false
          },
          {
            "name": "password",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Task result"
          }
        }
      }
    },
    "/OpenRedirect/realRedirect": {
      "get": {
        "summary": "Redirect to any URL",
        "operationId": "openRedirectReal",
        "tags": ["Open Redirect"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect"
          }
        }
      }
    },
    "/OpenRedirect/task1": {
      "get": {
        "summary": "Open redirect task 1",
        "operationId": "openRedirectTask1",
        "tags": ["Open Redirect"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect"
          }
        }
      }
    },
    "/OpenRedirect/task2": {
      "post": {
        "summary": "Open redirect task 2",
        "operationId": "openRedirectTask2",
        "tags": ["Open Redirect"],
        "parameters": [
          {
            "in": "formData",
            "name": "redirect",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "returnUrl",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Result"
          }
        }
      }
    },
    "/CrossSiteScripting/attack1": {
      "post": {
        "summary": "XSS reflected attack 1",
