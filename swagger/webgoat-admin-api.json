                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "salary": {
                        "type": "integer"
                      },
                      "ssn": {
                        "type": "string"
                      },
                      "department": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/clientSideFiltering/attack1": {
      "post": {
        "summary": "Client side filtering attack",
        "operationId": "clientSideFilteringAttack",
        "tags": ["Client Side Filtering"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "answer": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attack result"
          }
        }
      }
    },
