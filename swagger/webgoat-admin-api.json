{
  "swagger": "2.0",
  "info": {
    "title": "WebGoat Admin & Access Control API",
    "description": "Admin endpoints, Actuator, IDOR, Missing Access Control, and Challenge endpoints",
    "version": "1.0.0",
    "contact": {
      "name": "WebGoat Security"
    }
  },
  "host": "localhost:8080",
  "basePath": "/WebGoat",
  "schemes": [
    "http"
  ],
  "consumes": [
    "application/json",
    "application/x-www-form-urlencoded"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "BasicAuth": {
      "type": "basic"
    },
    "AdminApiKey": {
      "type": "apiKey",
      "in": "header",
      "name": "X-Admin-Key"
    }
  },
  "paths": {
    "/actuator/env": {
      "get": {
        "summary": "Expose all environment variables",
        "operationId": "actuatorEnv",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "Full env including DB passwords, API keys, secrets",
            "schema": {
              "type": "object",
              "properties": {
                "activeProfiles": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "propertySources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "properties": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/actuator/health": {
      "get": {
        "summary": "Get application health details",
        "operationId": "actuatorHealth",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "Health status with internal details"
          }
        }
      }
    },
    "/actuator/configprops": {
      "get": {
        "summary": "Get all config properties including secrets",
        "operationId": "actuatorConfigProps",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "Full config properties",
            "schema": {
              "type": "object",
              "properties": {
                "contexts": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/actuator/beans": {
      "get": {
        "summary": "Get all Spring beans",
        "operationId": "actuatorBeans",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "All Spring bean definitions"
          }
        }
      }
    },
    "/actuator/mappings": {
      "get": {
        "summary": "Get all request handler mappings",
        "operationId": "actuatorMappings",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "All HTTP request mappings exposed"
          }
        }
      }
    },
    "/access-control/users": {
      "get": {
        "summary": "Get all users - no access control",
        "operationId": "getAllUsers",
        "tags": ["Access Control"],
        "responses": {
          "200": {
            "description": "All users including passwords and secrets",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer"
                  },
                  "username": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  },
                  "secretKey": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create user - no admin check",
        "operationId": "createUser",
        "tags": ["Access Control"],
        "parameters": [
          {
            "in": "body",
            "name": "user",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                },
                "role": {
                  "type": "string"
                },
                "isAdmin": {
                  "type": "boolean"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User created"
          }
        }
      }
    },
    "/access-control/users/{userId}": {
      "delete": {
        "summary": "Delete any user without authorization",
        "operationId": "deleteUser",
        "tags": ["Access Control"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        }
      },
      "put": {
        "summary": "Update user role - privilege escalation",
        "operationId": "updateUserRole",
        "tags": ["Access Control"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "isAdmin": {
                  "type": "boolean"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User updated"
          }
        }
      }
    },
    "/IDOR/login": {
      "post": {
        "summary": "IDOR lesson login",
        "operationId": "idorLogin",
        "tags": ["IDOR"],
        "parameters": [
          {
            "in": "formData",
            "name": "username",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "password",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Login result"
          }
        }
      }
    },
    "/IDOR/profile/{userId}": {
      "get": {
        "summary": "Get any user profile by ID - IDOR",
        "operationId": "getProfileById",
        "tags": ["IDOR"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "User profile with sensitive fields",
            "schema": {
              "type": "object",
              "properties": {
                "userId": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "address": {
                  "type": "string"
                },
                "phone": {
                  "type": "string"
                },
                "ssn": {
                  "type": "string"
                },
                "creditCard": {
                  "type": "string"
                },
                "salary": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update any user profile - no ownership check",
        "operationId": "updateProfileById",
        "tags": ["IDOR"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "profile",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "address": {
                  "type": "string"
                },
                "phone": {
                  "type": "string"
                },
                "role": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile updated"
          }
        }
      }
    },
    "/IDOR/diff-attributes": {
      "get": {
        "summary": "Get diff attributes - mass assignment",
        "operationId": "idorDiffAttributes",
        "tags": ["IDOR"],
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "type": "integer",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Attributes"
          }
        }
      }
    },
    "/IDOR/profile/alt-path": {
      "get": {
        "summary": "Access profile via alt path",
        "operationId": "getProfileAltPath",
        "tags": ["IDOR"],
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "type": "integer",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Profile"
          }
        }
      }
    },
    "/SecurityMisconfiguration/task2/config": {
      "get": {
        "summary": "Expose sensitive configuration",
        "operationId": "getConfig",
        "tags": ["Security Misconfiguration"],
        "responses": {
          "200": {
            "description": "Sensitive config exposed",
            "schema": {
              "type": "object",
              "properties": {
                "dbHost": {
                  "type": "string"
                },
                "dbPassword": {
                  "type": "string"
                },
                "apiKey": {
                  "type": "string"
                },
                "adminToken": {
                  "type": "string"
                },
                "secretKey": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/SecurityMisconfiguration/task2/trigger": {
      "get": {
        "summary": "Trigger verbose error with stack trace",
        "operationId": "triggerMisconfiguration",
        "tags": ["Security Misconfiguration"],
        "responses": {
          "200": {
            "description": "Result"
          },
          "500": {
            "description": "Stack trace and internal details exposed"
          }
        }
      }
    },
    "/service/reportcard.mvc": {
      "get": {
        "summary": "Get report card for all users",
        "operationId": "getReportCard",
        "tags": ["Service"],
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "type": "integer",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Report card data",
            "schema": {
              "type": "object",
              "properties": {
                "lessonStatistics": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "lessonName": {
                        "type": "string"
                      },
                      "solved": {
                        "type": "boolean"
                      },
                      "attempts": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/service/restartlesson.mvc/{lesson}": {
      "post": {
        "summary": "Restart any user's lesson",
        "operationId": "restartLesson",
        "tags": ["Service"],
        "parameters": [
          {
            "name": "lesson",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "userId",
            "in": "query",
            "type": "integer",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Lesson restarted"
          }
        }
      }
    },
    "/service/enable-security.mvc": {
      "get": {
        "summary": "Toggle security settings",
        "operationId": "enableSecurity",
        "tags": ["Service"],
        "parameters": [
          {
            "name": "enabled",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Security toggled"
          }
        }
      }
    },
    "/challenge/7/.git": {
      "get": {
        "summary": "Exposed git repository",
        "operationId": "challengeGitDir",
        "tags": ["Challenges"],
        "responses": {
          "200": {
            "description": "Git repository contents including source code and secrets"
          }
        }
      }
    },
    "/challenge/7/reset-password/{link}": {
      "post": {
        "summary": "Reset password for any account",
        "operationId": "challengeResetPassword",
        "tags": ["Challenges"],
        "parameters": [
          {
            "name": "link",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "newPassword": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Password changed"
          }
        }
      }
    },
    "/challenge/8/votes/{stars}": {
      "post": {
        "summary": "Vote without auth",
        "operationId": "challengeVote",
        "tags": ["Challenges"],
        "parameters": [
          {
            "name": "stars",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Vote recorded"
          }
        }
      }
    },
    "/challenge/8/votes/": {
      "get": {
        "summary": "Get all votes",
        "operationId": "challengeGetVotes",
        "tags": ["Challenges"],
        "responses": {
          "200": {
            "description": "All votes",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "user": {
                    "type": "string"
                  },
                  "stars": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/missingac/users": {
      "get": {
        "summary": "All users without access control",
        "operationId": "missingAcUsers",
        "tags": ["Missing Access Control"],
        "responses": {
          "200": {
            "description": "Full user list",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer"
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/missingac/addUser": {
      "post": {
        "summary": "Add user with admin flag - no auth",
        "operationId": "missingAcAddUser",
        "tags": ["Missing Access Control"],
        "parameters": [
          {
            "in": "body",
            "name": "user",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                },
                "admin": {
                  "type": "boolean"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User added"
          }
        }
      }
    },
    "/missingac/deleteUser/{userId}": {
      "delete": {
        "summary": "Delete any user - no auth check",
        "operationId": "missingAcDeleteUser",
        "tags": ["Missing Access Control"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        }
      }
    },
    "/HttpProxies/intercept-request": {
      "get": {
        "summary": "Intercept HTTP request",
        "operationId": "httpProxiesGet",
        "tags": ["HTTP Proxies"],
        "parameters": [
          {
            "name": "changeMe",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Request details"
          }
        }
      },
      "post": {
        "summary": "Intercept and modify POST request",
        "operationId": "httpProxiesPost",
        "tags": ["HTTP Proxies"],
        "parameters": [
          {
            "in": "formData",
            "name": "changeMe",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Modified request result"
          }
        }
      }
    },
    "/ChromeDevTools/dummy": {
      "get": {
        "summary": "Chrome DevTools dummy endpoint",
        "operationId": "chromeDevToolsDummyGet",
        "tags": ["Chrome DevTools"],
        "parameters": [
          {
            "name": "devtools",
            "in": "query",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Response"
          }
        }
      },
      "post": {
        "summary": "Chrome DevTools dummy POST",
        "operationId": "chromeDevToolsDummyPost",
        "tags": ["Chrome DevTools"],
        "parameters": [
          {
            "in": "formData",
            "name": "devtools",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Response"
          }
        }
      }
    },
    "/ChromeDevTools/network": {
      "get": {
        "summary": "Get network request data",
        "operationId": "chromeDevToolsNetwork",
        "tags": ["Chrome DevTools"],
        "parameters": [
          {
            "name": "networkNum",
            "in": "query",
            "type": "integer",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Network data"
          }
        }
      }
    }
  }
}
