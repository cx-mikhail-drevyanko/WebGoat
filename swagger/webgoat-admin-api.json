{
  "swagger": "2.0",
  "info": {
    "title": "WebGoat Admin & Access Control API",
    "description": "Admin, Actuator, IDOR, Missing Access Control, and Challenge endpoints",
    "version": "1.0.0",
    "contact": {
      "name": "WebGoat Security",
      "email": "webgoat@owasp.org"
    }
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "consumes": [
    "application/json",
    "application/x-www-form-urlencoded"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "BasicAuth": {
      "type": "basic"
    },
    "AdminToken": {
      "type": "apiKey",
      "in": "header",
      "name": "X-Admin-Token"
    }
  },
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "paths": {
    "/WebGoat/actuator/env": {
      "get": {
        "summary": "Expose all environment variables including secrets",
        "operationId": "actuatorEnv",
        "tags": ["Actuator"],
        "security": [],
        "responses": {
          "200": {
            "description": "Full environment config including DB passwords, API keys, and secrets",
            "schema": {
              "type": "object",
              "properties": {
                "activeProfiles": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "propertySources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string"},
                      "properties": {"type": "object"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/WebGoat/actuator/health": {
      "get": {
        "summary": "Get application health with internals",
        "operationId": "actuatorHealth",
        "tags": ["Actuator"],
        "security": [],
        "responses": {
          "200": {
            "description": "Health status including database and disk details"
          }
        }
      }
    },
    "/WebGoat/actuator/configprops": {
      "get": {
        "summary": "Expose all config properties including secrets",
        "operationId": "actuatorConfigProps",
        "tags": ["Actuator"],
        "security": [],
        "responses": {
          "200": {
            "description": "All configuration properties",
            "schema": {
              "type": "object",
              "properties": {
                "contexts": {"type": "object"}
              }
            }
          }
        }
      }
    },
    "/WebGoat/actuator/beans": {
      "get": {
        "summary": "Get all Spring beans - internal architecture exposed",
        "operationId": "actuatorBeans",
        "tags": ["Actuator"],
        "security": [],
        "responses": {
          "200": {
            "description": "All Spring bean definitions"
          }
        }
      }
    },
    "/WebGoat/actuator/mappings": {
      "get": {
        "summary": "Get all request handler mappings",
        "operationId": "actuatorMappings",
        "tags": ["Actuator"],
        "security": [],
        "responses": {
          "200": {
            "description": "All HTTP handler mappings exposed"
          }
        }
      }
    },
    "/WebGoat/access-control/users": {
      "get": {
        "summary": "Get all users including passwords - broken access control",
        "operationId": "getAllUsers",
        "tags": ["Access Control"],
        "security": [],
        "responses": {
          "200": {
            "description": "Full user list with sensitive fields",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "integer"},
                  "username": {"type": "string"},
                  "email": {"type": "string"},
                  "password": {"type": "string"},
                  "role": {"type": "string"},
                  "secretKey": {"type": "string"},
                  "apiToken": {"type": "string"}
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create user with admin flag - mass assignment",
        "operationId": "createUser",
        "tags": ["Access Control"],
        "security": [],
        "parameters": [
          {
            "in": "body",
            "name": "user",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": {"type": "string"},
                "email": {"type": "string"},
                "password": {"type": "string"},
                "role": {"type": "string"},
                "isAdmin": {"type": "boolean"},
                "secretKey": {"type": "string"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User created - any role can be assigned"
          }
        }
      }
    },
    "/WebGoat/access-control/users/{userId}": {
      "delete": {
        "summary": "Delete any user without authorization",
        "operationId": "deleteUser",
        "tags": ["Access Control"],
        "security": [],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        }
      },
      "put": {
        "summary": "Update any user role - privilege escalation",
        "operationId": "updateUserRole",
        "tags": ["Access Control"],
        "security": [],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "role": {"type": "string"},
                "isAdmin": {"type": "boolean"},
                "permissions": {"type": "string"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Role updated - privilege escalation achieved"
          }
        }
      }
    },
