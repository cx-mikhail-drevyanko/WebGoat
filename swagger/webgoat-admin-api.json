    },
    "/challenge/8/votes/": {
      "get": {
        "summary": "Get all votes",
        "operationId": "challengeGetVotes",
        "tags": ["Challenges"],
        "responses": {
          "200": {
            "description": "All votes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "user": {
                        "type": "string"
                      },
                      "stars": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/challenge/flag/{flagNumber}": {
