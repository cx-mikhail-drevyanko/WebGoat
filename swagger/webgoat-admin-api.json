    },
    "/WebGoat/IDOR/profile/{userId}": {
      "get": {
        "summary": "Get any user profile by ID - BOLA/IDOR",
        "operationId": "getProfileById",
        "tags": ["IDOR"],
        "security": [],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "Any user ID - no object level authorization check"
          }
        ],
        "responses": {
          "200": {
            "description": "Full profile including sensitive data for any user",
            "schema": {
              "type": "object",
              "properties": {
                "userId": {"type": "integer"},
                "name": {"type": "string"},
                "email": {"type": "string"},
                "address": {"type": "string"},
                "phone": {"type": "string"},
                "ssn": {"type": "string"},
                "creditCard": {"type": "string"},
                "salary": {"type": "integer"},
                "password": {"type": "string"},
                "secretQuestion": {"type": "string"},
                "secretAnswer": {"type": "string"}
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update any user profile - no ownership check",
        "operationId": "updateProfileById",
        "tags": ["IDOR"],
        "security": [],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "profile",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "email": {"type": "string"},
                "address": {"type": "string"},
                "phone": {"type": "string"},
                "role": {"type": "string"},
                "isAdmin": {"type": "boolean"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile updated for any user"
          }
        }
      }
    },
