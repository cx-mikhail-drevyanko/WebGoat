{
  "openapi": "3.0.0",
  "info": {
    "title": "WebGoat Admin & Access Control API",
    "description": "API endpoints for Admin, Actuator, IDOR, Access Control, and Challenge lessons",
    "version": "1.0.0",
    "contact": {
      "name": "WebGoat"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080/WebGoat",
      "description": "Local WebGoat instance"
    }
  ],
  "paths": {
    "/actuator/env": {
      "get": {
        "summary": "Get all environment variables and configuration",
        "operationId": "actuatorEnv",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "Full environment configuration including secrets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "activeProfiles": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "propertySources": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "properties": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/actuator/health": {
      "get": {
        "summary": "Get application health",
        "operationId": "actuatorHealth",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "Health status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "components": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/actuator/configprops": {
      "get": {
        "summary": "Get all configuration properties",
        "operationId": "actuatorConfigProps",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "All configuration properties including sensitive values",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contexts": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/actuator/beans": {
      "get": {
        "summary": "Get all Spring beans",
        "operationId": "actuatorBeans",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "Bean definitions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/actuator/mappings": {
      "get": {
        "summary": "Get all request mappings",
        "operationId": "actuatorMappings",
        "tags": ["Actuator"],
        "responses": {
          "200": {
            "description": "All request handler mappings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/access-control/users": {
      "get": {
        "summary": "Get all users - missing access control",
        "operationId": "getAllUsers",
        "tags": ["Access Control"],
        "responses": {
          "200": {
            "description": "List of all users including sensitive data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer"
                      },
                      "username": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string"
                      },
                      "password": {
                        "type": "string"
                      },
                      "role": {
                        "type": "string"
                      },
                      "secretKey": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create user - no admin check",
        "operationId": "createUser",
        "tags": ["Access Control"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  },
                  "isAdmin": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created"
          }
        }
      }
    },
    "/access-control/users/{userId}": {
      "delete": {
        "summary": "Delete user - no authorization",
        "operationId": "deleteUser",
        "tags": ["Access Control"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        }
      },
      "put": {
        "summary": "Update user role - privilege escalation possible",
        "operationId": "updateUserRole",
        "tags": ["Access Control"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "role": {
                    "type": "string"
                  },
                  "isAdmin": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated"
          }
        }
      }
    },
    "/IDOR/profile/{userId}": {
      "get": {
        "summary": "Get user profile by ID - IDOR vulnerable",
        "operationId": "getProfileById",
        "tags": ["IDOR"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User profile including sensitive data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userId": {
                      "type": "integer"
                    },
                    "name": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "address": {
                      "type": "string"
                    },
                    "phone": {
                      "type": "string"
                    },
                    "ssn": {
                      "type": "string"
                    },
                    "creditCard": {
                      "type": "string"
                    },
                    "salary": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update user profile - no ownership check",
        "operationId": "updateProfileById",
        "tags": ["IDOR"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "address": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated"
          }
        }
      }
    },
    "/IDOR/profile/alt-path": {
      "get": {
        "summary": "Get profile via alternate path",
        "operationId": "getProfileAltPath",
        "tags": ["IDOR"],
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile data"
          }
        }
      }
    },
    "/clientSideFiltering/salaries": {
      "get": {
        "summary": "Get all employee salaries - sensitive data exposure",
